{
  // Use IntelliSense to learn about possible attributes.
  // Hover to view descriptions of existing attributes.
  // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
  "version": "0.2.0",
  "configurations": [
    {
      "name": "download",
      "type": "debugpy",
      "request": "launch",
      "module": "usdx_dl",
      "cwd": "${workspaceFolder}",
      "args": ["https://www.youtube.com/watch?v=fOs0G3KLdY4", "-f", "txt"],
      "console": "integratedTerminal",
      "justMyCode": false
    },
    {
      "name": "web",
      "type": "debugpy",
      "request": "launch",
      "module": "usdx_dl",
      "cwd": "${workspaceFolder}",
      "args": ["web", "--tee", "--host", "0.0.0.0"],
      "console": "integratedTerminal",
      "justMyCode": false
    },
    {
      "name": "gui",
      "type": "debugpy",
      "request": "launch",
      "module": "usdx_dl",
      "cwd": "${workspaceFolder}",
      "args": [],
      "console": "integratedTerminal",
      "justMyCode": false
    },
    {
      "name": "current file",
      "type": "debugpy",
      "request": "launch",
      "program": "${file}",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": false
    },
    {
      "name": "current file with args",
      "type": "debugpy",
      "request": "launch",
      "program": "${file}",
      "cwd": "${workspaceFolder}",
      "args": "${command:pickArgs}",
      "console": "integratedTerminal",
      "justMyCode": false
    }
  ]
}
