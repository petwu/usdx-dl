# generated frontend build output
dist/** linguist-generated

# treat built assets as generated text with simple diffs
dist/**/*.js text eol=lf
dist/**/*.css text eol=lf
dist/**/*.html text eol=lf
dist/**/*.json text eol=lf
dist/**/*.svg text eol=lf

# binary assets
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
